digraph RPC_NCN_Architecture {
    // Graph settings
    rankdir=TB;
    compound=true;
    node [shape=box, style=rounded, fontname="Arial"];
    edge [fontname="Arial", fontsize=10];

    // Title
    labelloc="t";
    label="RPC-NCN Architecture\nVerified RPC Infrastructure with Latency Guarantees";
    fontsize=16;
    fontname="Arial Bold";

    // Client Layer
    subgraph cluster_client {
        label="Client Layer";
        style=filled;
        color=lightblue;

        Client [label="Client Application\n(TypeScript SDK)", shape=box, style="rounded,filled", fillcolor=lightcyan];
        ApiKey [label="API Key\n(Subscription)", shape=note, fillcolor=lightyellow];
    }

    // Gateway Layer
    subgraph cluster_gateway {
        label="Gateway Layer";
        style=filled;
        color=lightgreen;

        Gateway [label="Gateway\n(TypeScript/Node.js)", shape=component, fillcolor=lightgreen];
        Router [label="Request Router", shape=box, fillcolor=palegreen];
        Aggregator [label="Response Aggregator", shape=box, fillcolor=palegreen];
        VerificationEngine [label="Signature Verifier\n(Threshold Check)", shape=box, fillcolor=palegreen];
        MetricsCollector [label="Metrics Tracker\n(Latency, Success Rate)", shape=box, fillcolor=palegreen];

        Gateway -> Router;
        Router -> Aggregator;
        Aggregator -> VerificationEngine;
        VerificationEngine -> MetricsCollector;
    }

    // Operator Layer
    subgraph cluster_operators {
        label="Operator Layer";
        style=filled;
        color=lightyellow;

        Operator1 [label="Operator 1\n(Rust RPC Proxy)", shape=box3d, fillcolor=yellow];
        Operator2 [label="Operator 2\n(Rust RPC Proxy)", shape=box3d, fillcolor=yellow];
        Operator3 [label="Operator N\n(Rust RPC Proxy)", shape=box3d, fillcolor=yellow];

        OperatorFunctions [label="Functions:\n• Serve RPC requests\n• Sign responses (ED25519)\n• Measure peer latency\n• Stake collateral", shape=note, fillcolor=lightyellow];
    }

    // Latency Attestation Network
    subgraph cluster_latency {
        label="Latency Attestation Network";
        style=dashed;
        color=orange;

        LatencyAttestation [label="Peer-to-Peer\nLatency Measurement", shape=diamond, fillcolor=orange];
        ChallengeResponse [label="Challenge-Response Protocol:\n1. Send challenge(nonce)\n2. Receive signed response\n3. Calculate RTT\n4. Aggregate P50/P95/P99", shape=note, fillcolor=wheat];
    }

    // Solana Settlement Layer
    subgraph cluster_solana {
        label="Solana Settlement Layer\n(Jito Restaking)";
        style=filled;
        color=lightpink;

        SolanaRPC [label="Solana RPC\nNodes", shape=cylinder, fillcolor=pink];

        subgraph cluster_programs {
            label="On-Chain Programs (Anchor)";
            style=filled;
            color=mistyrose;

            Registry [label="Registry\n(Operators/Subscriptions)", shape=folder, fillcolor=mistyrose];
            StakeCustody [label="Stake Custody\n(Operator Collateral)", shape=folder, fillcolor=mistyrose];
            SlashingEngine [label="Slashing Engine\n(Penalties)", shape=folder, fillcolor=mistyrose];
            RewardsDistribution [label="Rewards Distribution\n(Fee Distribution)", shape=folder, fillcolor=mistyrose];
        }
    }

    // Verification Tiers
    VerificationTiers [label="Verification Tiers:\n━━━━━━━━━━━━━━━━━━━\nBasic: 1 op, 100ms, $0.0001/req\nStandard: 3-5 ops, 50ms, $0.0005/req\nPremium: 5+ ops, 20ms, $0.001/req\nEnterprise: 7+ ops, 10ms, $0.005/req", shape=note, fillcolor=lavender];

    // Main data flow
    Client -> Gateway [label="1. Request\n+ API Key", color=blue, penwidth=2];
    Gateway -> Router [label="2. Lookup\nSubscription", style=dashed];
    Router -> Operator1 [label="3. Fanout to\nN operators", color=blue, penwidth=2];
    Router -> Operator2 [label="3. Fanout", color=blue];
    Router -> Operator3 [label="3. Fanout", color=blue];

    Operator1 -> SolanaRPC [label="4. Query RPC", color=green];
    Operator2 -> SolanaRPC [label="4. Query RPC", color=green];
    Operator3 -> SolanaRPC [label="4. Query RPC", color=green];

    Operator1 -> Aggregator [label="5. Signed\nResponse", color=red];
    Operator2 -> Aggregator [label="5. Signed\nResponse", color=red];
    Operator3 -> Aggregator [label="5. Signed\nResponse", color=red];

    Aggregator -> Client [label="7. Verified Response\n+ Proof", color=purple, penwidth=2];

    // Gateway-Solana interactions
    Router -> Registry [label="Check subscription tier", style=dotted];
    MetricsCollector -> RewardsDistribution [label="Report metrics", style=dotted];

    // Operator-Settlement interactions
    Operator1 -> StakeCustody [label="Stake\ncollateral", style=dotted, color=green];
    Operator2 -> StakeCustody [style=dotted, color=green];
    Operator3 -> StakeCustody [style=dotted, color=green];

    SlashingEngine -> Operator1 [label="Slash for\nmisbehavior", style=dotted, color=red];
    RewardsDistribution -> Operator1 [label="Distribute\nfees", style=dotted, color=darkgreen];

    // Latency attestation
    Operator1 -> LatencyAttestation [style=dashed];
    Operator2 -> LatencyAttestation [style=dashed];
    Operator3 -> LatencyAttestation [style=dashed];
    LatencyAttestation -> Registry [label="Commit P50/P95/P99\nper epoch", style=dashed];

    // Client subscription
    ApiKey -> Client [style=invis];

    // Verification tiers reference
    Router -> VerificationTiers [style=dotted, label="Use tier"];

    // Operator functions reference
    Operator1 -> OperatorFunctions [style=invis];

    // Challenge response reference
    LatencyAttestation -> ChallengeResponse [style=invis];

    // Slashing conditions
    SlashingConditions [label="Slashing Conditions:\n━━━━━━━━━━━━━━━━━━\nIncorrect data: 10%\n(Merkle proof mismatch)\n\nLatency violation: 1%\n(Peer attestation)\n\nDowntime: 0.5%\n(Missing heartbeats)", shape=note, fillcolor=mistyrose];

    SlashingEngine -> SlashingConditions [style=invis];

    // Technology stack reference
    TechStack [label="Technology Stack:\n━━━━━━━━━━━━━━━━\nOperator: Rust\nGateway: TypeScript/Node.js\nContracts: Anchor (Rust)\nSDK: TypeScript\nStaking: Jito Restaking", shape=note, fillcolor=lightgray];

    {rank=same; VerificationTiers; TechStack; SlashingConditions;}
}
