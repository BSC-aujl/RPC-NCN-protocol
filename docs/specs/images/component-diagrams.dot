// RPC-NCN POC Component Diagrams
// Generate with: dot -Tpng component-diagrams.dot -o component-diagrams.png
// or: dot -Tsvg component-diagrams.dot -o component-diagrams.svg

digraph RPC_NCN_Components {
    // Graph settings
    rankdir=TB;
    compound=true;
    node [shape=box, style=rounded, fontname="Arial"];
    edge [fontname="Arial", fontsize=10];
    splines=ortho;

    // Title
    labelloc="t";
    label="RPC-NCN POC Component Architecture";
    fontsize=18;
    fontname="Arial Bold";

    // ========================================
    // ON-CHAIN PROGRAM (contracts/)
    // ========================================
    subgraph cluster_contracts {
        label="On-Chain Program (Anchor/Rust)\ncontracts/programs/rpc-ncn/";
        style=filled;
        color=lightpink;
        fontsize=14;

        // State Accounts
        subgraph cluster_state {
            label="State Accounts";
            style=filled;
            color=mistyrose;

            NCN [label="NCN\n━━━━━━━━━━━\n• authority: Pubkey\n• current_interval: u64\n• current_epoch: u64\n• total_stake: u64\n• operator_count: u8\n• requests_per_interval: u64", shape=folder, fillcolor=white];

            Operator [label="Operator\n━━━━━━━━━━━\n• owner: Pubkey\n• operator_id: String\n• signing_pubkey: [u8;32]\n• stake: u64\n• is_active: bool\n• correct_intervals: u32\n• offense_count: u8", shape=folder, fillcolor=white];

            Interval [label="Interval\n━━━━━━━━━━━\n• interval_id: u64\n• epoch: u64\n• consensus_hash: Option<[u8;32]>\n• quorum_bps: u16\n• finalized: bool\n• attestation_count: u8", shape=folder, fillcolor=white];

            Attestation [label="OperatorAttestation\n━━━━━━━━━━━\n• operator: Pubkey\n• interval_id: u64\n• state_hash: [u8;32]\n• signature: [u8;64]\n• submitted_at: i64", shape=folder, fillcolor=white];
        }

        // Instructions
        subgraph cluster_instructions {
            label="Instructions";
            style=filled;
            color=lightcoral;

            Initialize [label="initialize\n━━━━━━━━━━━\nCreate NCN account\nSet configuration", shape=component, fillcolor=white];

            RegisterOperator [label="register_operator\n━━━━━━━━━━━\nCreate operator PDA\nSet signing pubkey", shape=component, fillcolor=white];

            SyncOperatorStake [label="sync_operator_stake\n━━━━━━━━━━━\nUpdate stake amount\nUpdate NCN totals", shape=component, fillcolor=white];

            CreateInterval [label="create_interval\n━━━━━━━━━━━\nCreate new interval\nAdvance current_interval", shape=component, fillcolor=white];

            SubmitAttestation [label="submit_attestation\n━━━━━━━━━━━\n• Verify ED25519 sig\n• Store attestation\n• Auto-create next interval\n• Auto-advance epoch", shape=component, fillcolor=lightyellow];

            FinalizeInterval [label="finalize_interval\n━━━━━━━━━━━\nCompute consensus hash\nCalculate quorum %\nUpdate operator stats", shape=component, fillcolor=white];

            FinalizeEpoch [label="finalize_epoch\n━━━━━━━━━━━\nDistribute rewards\nTrack offenses\nReset counters", shape=component, fillcolor=white];

            CloseAccount [label="close_account\n━━━━━━━━━━━\nReclaim rent\nReturn lamports", shape=component, fillcolor=white];
        }

        // PDA Seeds
        PDAs [label="PDA Seeds\n━━━━━━━━━━━━━━━━━\nNCN: [\"ncn\"]\nOperator: [\"operator\", operator_id]\nInterval: [\"interval\", ncn, interval_id]\nAttestation: [\"attestation\", operator, interval_id]", shape=note, fillcolor=lightyellow];
    }

    // ========================================
    // OPERATOR NODE (operator-node/)
    // ========================================
    subgraph cluster_operator {
        label="Operator Node (Rust)\noperator-node/src/";
        style=filled;
        color=lightyellow;
        fontsize=14;

        // Main entry
        OperatorMain [label="main.rs\n━━━━━━━━━━━\n• Parse env config\n• Start HTTP server\n• Wire up attestation callback\n• Handle interval transitions", shape=box3d, fillcolor=yellow];

        // Modules
        subgraph cluster_op_modules {
            label="Core Modules";
            style=filled;
            color=khaki;

            RpcProxy [label="rpc_proxy.rs\n━━━━━━━━━━━\n• Proxy to Solana RPC\n• Sign responses (ED25519)\n• Return signed envelope", shape=component, fillcolor=white];

            HashChainMod [label="hash_chain.rs\n━━━━━━━━━━━\n• Sequential response hashing\n• SHA256 chain: H(prev || current)\n• Reset on interval change\n• Track response count", shape=component, fillcolor=white];

            IntervalHandler [label="interval_handler.rs\n━━━━━━━━━━━\n• Track current interval\n• Detect transitions\n• Trigger attestation callback\n• Epoch detection", shape=component, fillcolor=white];

            AttestSubmitter [label="attestation_submitter.rs\n━━━━━━━━━━━\n• Build submit_attestation tx\n• Derive PDAs\n• Sign with operator key\n• Submit to Solana", shape=component, fillcolor=lightyellow];

            Signer [label="signer.rs\n━━━━━━━━━━━\n• ED25519 keypair\n• Sign attestation data\n• Load from file", shape=component, fillcolor=white];
        }

        // Flow
        OperatorMain -> RpcProxy [label="handle request"];
        RpcProxy -> HashChainMod [label="add to chain"];
        OperatorMain -> IntervalHandler [label="check interval"];
        IntervalHandler -> AttestSubmitter [label="on interval end"];
        AttestSubmitter -> Signer [label="sign attestation"];
    }

    // ========================================
    // GATEWAY (gateway/)
    // ========================================
    subgraph cluster_gateway {
        label="Gateway (TypeScript/Node.js)\ngateway/src/";
        style=filled;
        color=lightgreen;
        fontsize=14;

        // Main entry
        GatewayIndex [label="index.ts\n━━━━━━━━━━━\n• Express HTTP server\n• POST /rpc endpoint\n• Operator registration\n• Subscription management\n• Sync on-chain state", shape=box3d, fillcolor=palegreen];

        // Modules
        subgraph cluster_gw_modules {
            label="Core Modules";
            style=filled;
            color=lightseagreen;

            Router [label="router.ts\n━━━━━━━━━━━\n• Select operators\n• Fanout requests\n• Add interval metadata\n• Handle timeouts", shape=component, fillcolor=white];

            Aggregator [label="aggregator.ts\n━━━━━━━━━━━\n• Collect responses\n• Verify signatures\n• Stake-weighted voting\n• ≥2/3 consensus check", shape=component, fillcolor=lightyellow];

            IntervalMgr [label="interval.ts\n━━━━━━━━━━━\n• Track request count\n• Advance intervals\n• Sync from on-chain\n• Emit interval events", shape=component, fillcolor=white];

            OnChainClient [label="onchain.ts\n━━━━━━━━━━━\n• Read NCN state\n• Parse operators\n• Derive PDAs\n• StakeCache class", shape=component, fillcolor=white];

            CrankSvc [label="crank.ts\n━━━━━━━━━━━\n• Monitor epoch changes\n• Call finalize_epoch\n• Permissionless crank", shape=component, fillcolor=white];

            FinalizationSvc [label="finalization.ts\n━━━━━━━━━━━\n• Check deadline slots\n• Call finalize_interval\n• Update on-chain state", shape=component, fillcolor=white];
        }

        // Types
        Types [label="types.ts\n━━━━━━━━━━━\n• JsonRpcRequest/Response\n• Operator, Subscription\n• VerificationLevel\n• MultiSignedResponse", shape=note, fillcolor=lightyellow];

        // Flow
        GatewayIndex -> Router [label="route request"];
        Router -> Aggregator [label="responses"];
        GatewayIndex -> IntervalMgr [label="track interval"];
        GatewayIndex -> OnChainClient [label="sync state"];
        GatewayIndex -> CrankSvc [label="epoch finalization"];
        GatewayIndex -> FinalizationSvc [label="interval finalization"];
    }

    // ========================================
    // CLIENT SDK (client-sdk/)
    // ========================================
    subgraph cluster_sdk {
        label="Client SDK (TypeScript)\nclient-sdk/src/";
        style=filled;
        color=lightblue;
        fontsize=14;

        SDKClient [label="client.ts\n━━━━━━━━━━━\n• RpcNcnClient class\n• Make verified requests\n• Configure gateway URL", shape=component, fillcolor=lightcyan];

        SDKVerify [label="verify.ts\n━━━━━━━━━━━\n• Verify ED25519 sigs\n• Check consensus\n• Validate operator pubkeys", shape=component, fillcolor=lightcyan];

        SDKTypes [label="types.ts\n━━━━━━━━━━━\n• VerificationLevel\n• SignedResponse\n• VerificationResult", shape=note, fillcolor=lightyellow];
    }

    // ========================================
    // EXTERNAL CONNECTIONS
    // ========================================
    SolanaRPC [label="Solana RPC\n(testnet/mainnet)", shape=cylinder, fillcolor=lightgray];
    SolanaChain [label="Solana Blockchain", shape=cylinder, fillcolor=pink];

    // Cross-component connections
    OperatorMain -> SolanaRPC [label="proxy RPC", color=blue];
    AttestSubmitter -> SolanaChain [label="submit_attestation", color=red, penwidth=2];
    GatewayIndex -> SolanaChain [label="read state", color=green];
    CrankSvc -> SolanaChain [label="finalize_epoch", color=orange];
    FinalizationSvc -> SolanaChain [label="finalize_interval", color=orange];

    // Data flow legend
    Legend [label="Data Flow\n━━━━━━━━━━━━━━━━━\n→ Blue: RPC requests\n→ Red: Attestations\n→ Green: State reads\n→ Orange: Crank operations", shape=note, fillcolor=white];

    {rank=same; NCN; Operator; Interval; Attestation;}
    {rank=same; SolanaRPC; SolanaChain; Legend;}
}
